{
  "makefile.extensionOutputFolder": "./.vscode",
  // Nix
  "[nix]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "brettm12345.nixfmt-vscode"
  },
  "nixEnvSelector.nixFile": "${workspaceFolder}/flake.nix",
  // shell script
  "shellcheck.enable": true,
  "shellcheck.enableQuickFix": true,
  "shellcheck.run": "onSave",
  "[shellscript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "mkhl.shfmt"
  },
  // dprint
  "[json][jsonc][toml][markdown]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "dprint.dprint"
  },
  // Lua
  "[lua]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "sumneko.lua"
  },
  "workbench.colorCustomizations": {
    "activityBar.background": "#371B6D",
    "titleBar.activeBackground": "#4D2698",
    "titleBar.activeForeground": "#FCFCFE",
    "titleBar.inactiveBackground": "#361B6C",
    "titleBar.inactiveForeground": "#FAF9FD",
    "statusBar.background": "#361B6C",
    "statusBar.foreground": "#FAF9FD",
    "statusBar.debuggingBackground": "#361B6C",
    "statusBar.debuggingForeground": "#FAF9FD",
    "statusBar.noFolderBackground": "#361B6C",
    "statusBar.noFolderForeground": "#FAF9FD"
  }
}
